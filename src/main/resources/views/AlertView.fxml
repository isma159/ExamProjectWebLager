<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox prefWidth="480.0" spacing="20.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label text="You have unsaved changes">
                            <font>
                                <Font name="System Bold" size="21.0" />
                            </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="✕">
                            <font>
                                <Font size="20.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <Label text="Do you want to save them before closing?" wrapText="true">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>

                <HBox spacing="10.0">
                    <children>
                        <Button fx:id="discardBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" text="Discard changes" HBox.hgrow="ALWAYS" />
                        <Button fx:id="saveBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" text="Save changes" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>