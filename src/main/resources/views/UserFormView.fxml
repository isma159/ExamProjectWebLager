<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.*?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="570.0" prefWidth="900.0" stylesheets="@../css/mainStyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ScanHub.GUI.controllers.UserFormController">
   <children>
      <VBox styleClass="background" HBox.hgrow="ALWAYS">
          <padding>
            <Insets bottom="0" left="0" right="0" top="0" />
         </padding>
          <HBox alignment="CENTER_LEFT" prefHeight="56" spacing="12" styleClass="primary-navigation-bg">
              <padding>
               <Insets bottom="0" left="20" right="20" top="0" />
            </padding>
              <ImageView fitHeight="36.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                      <Image url="@../images/Green/WeblagerGreenIcon.png" />
                  </image>
              </ImageView>
              <Label fx:id="formTitle" styleClass="bold-lbl" text="Create user" textFill="WHITE" />
              <Region maxHeight="-Infinity" minHeight="-Infinity" prefHeight="60.0" HBox.hgrow="ALWAYS" />
              <Label fx:id="userIdLabel" text="" />
          </HBox>
         <HBox spacing="12.0" VBox.vgrow="ALWAYS">
            <children>
                 <VBox prefHeight="675.0" prefWidth="480.0" spacing="0">
                     <padding>
                     <Insets bottom="24" left="24" right="24" top="24" />
                  </padding>
                     <Label styleClass="bold-lbl" text="Username" />
                     <Region prefHeight="6" />
                     <TextField fx:id="usernameField" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="30" promptText="e.g. jens.hansen" styleClass="container" />
                     <Label fx:id="usernameError" managed="false" text="Username is required." visible="false" />
         
                     <Region prefHeight="18" />
                     <Label styleClass="bold-lbl" text="Password" />
                     <Region prefHeight="4" />
                     <Label fx:id="passwordHint" styleClass="lbl" text="Choose a password for this user." />
                     <Region prefHeight="8" />
                     <PasswordField fx:id="passwordField" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="30" promptText="Password" styleClass="container" />
                     <Label fx:id="passwordError" managed="false" text="Password is required." visible="false" />
                     <Region prefHeight="10" />
                     <PasswordField fx:id="confirmPasswordField" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="30" promptText="Confirm password" styleClass="container" />
                     <Label fx:id="confirmError" managed="false" text="Passwords do not match." visible="false" />
         
                     <Region prefHeight="18" />
                     <Label styleClass="bold-lbl" text="Role" />
                     <Region prefHeight="4" />
                     <Label styleClass="lbl" text="Defines what the user can access in the system." />
                     <Region prefHeight="8" />
                     <VBox fx:id="vboxRole" spacing="8">
                         <padding>
                        <Insets bottom="14" left="14" right="14" top="14" />
                     </padding>
                         <HBox alignment="TOP_LEFT" spacing="10">
                             <RadioButton fx:id="radioUSER">
                                 <toggleGroup>
                                     <ToggleGroup fx:id="toggleGroupRole" />
                                 </toggleGroup>
                             </RadioButton>
                             <VBox spacing="2">
                                 <Label styleClass="lbl" text="User" />
                                 <Label prefWidth="360" styleClass="lbl" text="Can select profiles, scan documents, review files, and export." wrapText="true" VBox.vgrow="ALWAYS" />
                             </VBox>
                         </HBox>
                         <Separator />
                         <HBox alignment="TOP_LEFT" spacing="10">
                             <RadioButton fx:id="radioADMIN" toggleGroup="$toggleGroupRole" />
                             <VBox spacing="2">
                                 <Label styleClass="lbl" text="Admin" />
                                 <Label prefWidth="360" styleClass="lbl" text="Full access. Can manage users, profiles, and view all logs." wrapText="true" VBox.vgrow="ALWAYS" />
                             </VBox>
                         </HBox>
                     <styleClass>
                        <String fx:value="card" />
                        <String fx:value="second-card-bg" />
                     </styleClass>
                     </VBox>
                  <styleClass>
                     <String fx:value="card" />
                     <String fx:value="card-bg" />
                  </styleClass>
                 </VBox>
               <VBox prefHeight="675.0" prefWidth="480.0" spacing="0">
                  <padding>
                     <Insets bottom="24" left="24" right="24" top="24" />
                  </padding>
                  <styleClass>
                     <String fx:value="card" />
                     <String fx:value="card-bg" />
                  </styleClass>
                  <children>
                     <Label styleClass="bold-lbl" text="Assign profiles" />
                     <Region prefHeight="4" />
                     <Label styleClass="lbl" text="Select which profiles this user can access." />
                     <Region prefHeight="8" />
                     <VBox prefHeight="200.0" prefWidth="100.0" VBox.vgrow="ALWAYS">
                        <styleClass>
                           <String fx:value="card" />
                           <String fx:value="card-bg" />
                        </styleClass>
                        <children>
                           <HBox alignment="CENTER" prefHeight="150.0" prefWidth="200.0" styleClass="half-card">
                              <children>
                                 <TextField fx:id="txtFldClientSearch" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="30.0" promptText="Search for clients" styleClass="container" HBox.hgrow="ALWAYS" />
                              </children>
                              <padding>
                                 <Insets left="12.0" right="12.0" top="12.0" />
                              </padding>
                           </HBox>
                           <HBox alignment="CENTER" styleClass="half-card-bottom" VBox.vgrow="ALWAYS">
                              <children>
                                 <CheckTreeView fx:id="clientTreeView" editable="true" showRoot="false" styleClass="tree-view-form" HBox.hgrow="ALWAYS" />
                              </children>
                              <padding>
                                 <Insets bottom="3.0" left="3.0" right="3.0" top="15.0" />
                              </padding>
                           </HBox>
                        </children>
                     </VBox>
                  </children>
               </VBox>
            </children>
            <VBox.margin>
               <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
            </VBox.margin>
         </HBox>
          <HBox alignment="CENTER_RIGHT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="45.0" prefWidth="520.0" spacing="8">
              <padding>
               <Insets left="12.0" right="12.0" />
            </padding>
              <Button onAction="#onClickCancel" prefHeight="30" styleClass="tertiary-btn" text="Cancel" />
              <Button fx:id="saveButton" defaultButton="true" onAction="#onClickSave" prefHeight="33" styleClass="primary-btn" text="Create user" />
          </HBox>
      </VBox>
   </children>
</HBox>
