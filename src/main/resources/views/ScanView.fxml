<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.controlsfx.control.*?>

<StackPane styleClass="background" stylesheets="@../css/mainStyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ScanHub.GUI.controllers.ScanController">
   <BorderPane fx:id="workspaceView" prefHeight="700.0" prefWidth="1280.0" styleClass="background">
      <top>
         <VBox>
            <HBox alignment="CENTER_LEFT" minHeight="-Infinity" prefHeight="75.0" prefWidth="1280.0" spacing="12.0" styleClass="card,card-bg,shadow">
               <padding>
                  <Insets bottom="14.0" left="18.0" right="18.0" top="14.0" />
               </padding>
               <children>
                  <ImageView fitHeight="60.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" styleClass="green-logo-h">
                     <image>
                        <Image url="@../images/Green/LogoGreen2H.png" />
                     </image>
                  </ImageView>
                  <Region prefHeight="42.0" prefWidth="420.0" HBox.hgrow="ALWAYS" />
                  <VBox alignment="CENTER" spacing="4.0">
                     <children>
                        <Label styleClass="h1" text="Scanning Workspace" />
                        <Label fx:id="lblSessionStatus" alignment="CENTER" prefWidth="240.0" styleClass="lbl" text="–" />
                     </children>
                  </VBox>
                  <Region prefHeight="42.0" prefWidth="60.0" HBox.hgrow="ALWAYS" />
                  <ToggleSwitch fx:id="darkMode" onMouseClicked="#onDarkModeToggle" prefHeight="30.0" prefWidth="60.0" scaleX="1.25" scaleY="1.25" scaleZ="1.25" text="Dark Mode ">
                     <HBox.margin>
                        <Insets right="12.0" />
                     </HBox.margin>
                  </ToggleSwitch>
                  <VBox alignment="CENTER_RIGHT" spacing="3.0">
                     <children>
                        <Label fx:id="lblUsername" styleClass="h3" text="Username" />
                        <Label fx:id="lblRole" styleClass="lbl" text="Role: User/Admin" />
                     </children>
                  </VBox>
                  <Separator orientation="VERTICAL" prefHeight="40.0" styleClass="grey-separator" />
                  <Button mnemonicParsing="false" onAction="#onExit" prefHeight="33.0" prefWidth="33.0" styleClass="primary-btn">
                     <graphic>
                        <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                           <font><Font size="16.0" /></font>
                        </Label>
                     </graphic>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
               </VBox.margin>
            </HBox>
         </VBox>
      </top>

      <left>
         <VBox prefWidth="240.0" styleClass="card,card-bg,shadow">
            <HBox alignment="CENTER_LEFT">
               <padding>
                  <Insets bottom="8.0" left="10.0" right="10.0" top="8.0" />
               </padding>
               <children>
                  <Label prefHeight="27.0" styleClass="lbl" text="Document Tree" HBox.hgrow="ALWAYS" />
               </children>
               <styleClass>
                  <String fx:value="card-bg" />
                  <String fx:value="half-card" />
               </styleClass>
            </HBox>
            <Separator prefWidth="200.0" styleClass="grey-separator" />
            <TreeView fx:id="boxTreeView" VBox.vgrow="ALWAYS">
               <styleClass>
                  <String fx:value="scan-list" />
                  <String fx:value="tree-view-scanner" />
               </styleClass>
               <VBox.margin>
                  <Insets bottom="3.0" left="3.0" right="3.0" />
               </VBox.margin>
            </TreeView>
            <BorderPane.margin>
               <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
            </BorderPane.margin>
         </VBox>
      </left>

      <center>
         <VBox>
            <children>
               <VBox alignment="CENTER">
                  <children>
                     <HBox alignment="CENTER" prefHeight="45.0" spacing="4.0">
                        <padding>
                           <Insets bottom="6.0" left="10.0" right="10.0" top="6.0" />
                        </padding>
                        <children>
                           <Button mnemonicParsing="false" onAction="#onSessionStartup" prefHeight="33.0" prefWidth="135.0" styleClass="secondary-btn">
                              <graphic>
                                 <HBox alignment="CENTER">
                                    <children>
                                       <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                          <font><Font size="16.0" /></font>
                                       </Label>
                                       <Region prefWidth="3.0" />
                                       <Label styleClass="bold-lbl" text="Session Startup" textFill="WHITE">
                                          <font><Font size="12.0" /></font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </graphic>
                           </Button>

                           <Separator maxHeight="-Infinity" orientation="VERTICAL" prefHeight="21.0" styleClass="grey-separator" />

                           <Button fx:id="btnScan" mnemonicParsing="false" onAction="#onScan" prefHeight="33.0" prefWidth="75.0" styleClass="primary-btn">
                              <graphic>
                                 <HBox alignment="CENTER">
                                    <children>
                                       <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                          <font><Font size="16.0" /></font>
                                       </Label>
                                       <Region prefWidth="3.0" />
                                       <Label styleClass="bold-lbl" text="Scan" textFill="WHITE">
                                          <font><Font size="12.0" /></font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </graphic>
                           </Button>

                           <Button fx:id="btnStop" mnemonicParsing="false" onAction="#onStop" prefHeight="33.0" prefWidth="75.0" styleClass="destructive-btn">
                              <graphic>
                                 <HBox alignment="CENTER">
                                    <children>
                                       <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                          <font><Font size="16.0" /></font>
                                       </Label>
                                       <Region prefWidth="3.0" />
                                       <Label styleClass="bold-lbl" text="Stop" textFill="WHITE">
                                          <font><Font size="12.0" /></font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </graphic>
                           </Button>

                           <Separator maxHeight="-Infinity" orientation="VERTICAL" prefHeight="21.0" styleClass="grey-separator" />

                           <Button fx:id="btnNewDoc" mnemonicParsing="false" onAction="#onNewDocument" prefHeight="33.0" prefWidth="90.0" styleClass="secondary-btn">
                              <graphic>
                                 <HBox alignment="CENTER">
                                    <children>
                                       <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                          <font><Font size="16.0" /></font>
                                       </Label>
                                       <Region prefWidth="3.0" />
                                       <Label styleClass="bold-lbl" text="New Doc" textFill="WHITE">
                                          <font><Font size="12.0" /></font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </graphic>
                           </Button>
                           <Button fx:id="btnSplitDoc" mnemonicParsing="false" onAction="#onSplitDocument" prefHeight="33.0" prefWidth="90.0" styleClass="secondary-btn">
                              <graphic>
                                 <HBox alignment="CENTER">
                                    <children>
                                       <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                          <font>
                                             <Font size="16.0" />
                                          </font>
                                       </Label>
                                       <Region prefWidth="3.0" />
                                       <Label styleClass="bold-lbl" text="Split Doc" textFill="WHITE">
                                          <font>
                                             <Font size="12.0" />
                                          </font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </graphic>
                           </Button>

                           <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#onDeleteFileOrDocument" prefHeight="33.0" prefWidth="75.0" styleClass="destructive-btn">
                              <graphic>
                                 <HBox alignment="CENTER">
                                    <children>
                                       <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                          <font><Font size="16.0" /></font>
                                       </Label>
                                       <Region prefWidth="3.0" />
                                       <Label styleClass="bold-lbl" text="Delete" textFill="WHITE">
                                          <font><Font size="12.0" /></font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </graphic>
                           </Button>

                           <Button fx:id="btnUndo" mnemonicParsing="false" onAction="#onUndo" prefHeight="33.0" prefWidth="75.0" styleClass="secondary-btn">
                              <graphic>
                                 <HBox alignment="CENTER">
                                    <children>
                                       <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                          <font><Font size="16.0" /></font>
                                       </Label>
                                       <Region prefWidth="3.0" />
                                       <Label styleClass="bold-lbl" text="Undo" textFill="WHITE">
                                          <font><Font size="12.0" /></font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </graphic>
                           </Button>

                           <Separator maxHeight="-Infinity" orientation="VERTICAL" prefHeight="21.0" styleClass="grey-separator" />

                           <Button fx:id="btnExport" mnemonicParsing="false" onAction="#onExport" prefHeight="33.0" prefWidth="75.0" styleClass="primary-btn">
                              <graphic>
                                 <HBox alignment="CENTER">
                                    <children>
                                       <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                          <font><Font size="16.0" /></font>
                                       </Label>
                                       <Region prefWidth="3.0" />
                                       <Label styleClass="bold-lbl" text="Export" textFill="WHITE">
                                          <font><Font size="12.0" /></font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </graphic>
                           </Button>

                           <ComboBox fx:id="comboBoxExport" prefWidth="163.0" styleClass="container" />
                        </children>

                        <VBox.margin>
                           <Insets />
                        </VBox.margin>
                     </HBox>
                  </children>

                  <styleClass>
                     <String fx:value="card-bg" />
                     <String fx:value="half-card" />
                  </styleClass>

                  <VBox.margin>
                     <Insets right="3.0" top="3.0" />
                  </VBox.margin>
               </VBox>

               <StackPane styleClass="background" VBox.vgrow="ALWAYS">

                  <ScrollPane fitToHeight="false" fitToWidth="true" pannable="true" styleClass="v-card">
                     <content>
                        <FlowPane fx:id="pageGrid" alignment="CENTER" columnHalignment="CENTER" hgap="16" vgap="16">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                        </FlowPane>
                     </content>

                     <StackPane.margin>
                        <Insets right="3.0" top="3.0" />
                     </StackPane.margin>
                  </ScrollPane>

                  <Label fx:id="lblEmptyState" styleClass="lbl" text="No pages scanned yet. Press Space or click Scan" textAlignment="CENTER" visible="true" wrapText="true" />
               </StackPane>

               <HBox alignment="CENTER" maxHeight="-Infinity" minWidth="-Infinity" prefHeight="45.0" prefWidth="200.0">
                  <styleClass>
                     <String fx:value="half-card-bottom" />
                     <String fx:value="card-bg" />
                  </styleClass>

                  <children>
                     <Button fx:id="btnZoomOut" mnemonicParsing="false" onAction="#onZoomOut" prefHeight="33.0" prefWidth="33.0" styleClass="secondary-btn">
                        <graphic>
                           <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                              <font><Font size="16.0" /></font>
                           </Label>
                        </graphic>

                        <HBox.margin>
                           <Insets left="3.0" right="3.0" />
                        </HBox.margin>
                     </Button>

                     <Button fx:id="btnZoomIn" mnemonicParsing="false" onAction="#onZoomIn" prefHeight="33.0" prefWidth="33.0" styleClass="secondary-btn">
                        <graphic>
                           <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                              <font><Font size="16.0" /></font>
                           </Label>
                        </graphic>

                        <HBox.margin>
                           <Insets left="3.0" right="3.0" />
                        </HBox.margin>
                     </Button>

                     <Separator maxHeight="-Infinity" orientation="VERTICAL" prefHeight="21.0" styleClass="grey-separator" />

                     <Button fx:id="btnRotLeft" mnemonicParsing="false" onAction="#onRotateLeft" prefHeight="33.0" prefWidth="90.0" styleClass="secondary-btn">
                        <graphic>
                           <HBox alignment="CENTER">
                              <children>
                                 <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                    <font>
                                       <Font size="16.0" />
                                    </font>
                                 </Label>
                                 <Region prefWidth="3.0" />
                                 <Label styleClass="bold-lbl" text="Rotate L" textFill="WHITE">
                                    <font>
                                       <Font size="12.0" />
                                    </font>
                                 </Label>
                              </children>
                           </HBox>
                        </graphic>
                        <HBox.margin>
                           <Insets left="3.0" right="3.0" />
                        </HBox.margin>
                     </Button>

                     <Button fx:id="btnRotRight" mnemonicParsing="false" onAction="#onRotateRight" prefHeight="33.0" prefWidth="90.0" styleClass="secondary-btn">
                        <graphic>
                           <HBox alignment="CENTER">
                              <children>
                                 <Label alignment="CENTER" prefHeight="16.0" prefWidth="16.0" styleClass="white-icon" text="">
                                    <font>
                                       <Font size="16.0" />
                                    </font>
                                 </Label>
                                 <Region prefWidth="3.0" />
                                 <Label styleClass="bold-lbl" text="Rotate R" textFill="WHITE">
                                    <font>
                                       <Font size="12.0" />
                                    </font>
                                 </Label>
                              </children>
                           </HBox>
                        </graphic>
                        <HBox.margin>
                           <Insets left="3.0" right="3.0" />
                        </HBox.margin>
                     </Button>
                  </children>

                  <VBox.margin>
                     <Insets bottom="3.0" right="3.0" />
                  </VBox.margin>
               </HBox>
            </children>

            <BorderPane.margin>
               <Insets top="3.0" />
            </BorderPane.margin>
         </VBox>
      </center>

      <bottom>
         <HBox alignment="CENTER_LEFT" spacing="16.0">
            <padding>
               <Insets bottom="4.0" left="12.0" right="12.0" top="4.0" />
            </padding>

            <children>
               <Label fx:id="stDocsLabel" styleClass="lbl" text="Documents: 0" />
               <Label alignment="CENTER" styleClass="lbl" text="|" />
               <Label fx:id="stPagesLabel" styleClass="lbl" text="Pages: 0" />
               <Label text="|" />
               <Label fx:id="pageInfoLabel" styleClass="lbl" text="0 / 0" />
               <Region HBox.hgrow="ALWAYS" />
               <Label styleClass="lbl" text="Space scan" />
               <Label styleClass="lbl" text="←→ nav" />
               <Label styleClass="lbl" text="[] rotate" />
               <Label styleClass="lbl" text="Del delete" />
               <Label styleClass="lbl" text="Ctrl+E export" />
               <Label styleClass="lbl" text="Ctrl+Z undo" />
            </children>

            <BorderPane.margin>
               <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
            </BorderPane.margin>

            <styleClass>
               <String fx:value="box-card" />
               <String fx:value="card-bg" />
               <String fx:value="shadow" />
            </styleClass>
         </HBox>
      </bottom>
   </BorderPane>

   <StackPane fx:id="sessionPopupOverlay" disable="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" visible="false">
      <VBox spacing="12.0" styleClass="card,card-bg,shadow" StackPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>

         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label styleClass="h2" text="Session Setup" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#onSessionPopupClose" prefHeight="28.0" styleClass="secondary-btn" text="✕" />
               </children>
            </HBox>

            <Label styleClass="lbl" text="Choose the assigned profile and enter the box ID." wrapText="true" />

            <VBox spacing="6.0">
               <children>
                  <Label styleClass="h3" text="Profile" />
                  <SearchableComboBox fx:id="comboBoxProfiles" prefWidth="320.0" />
               </children>
            </VBox>

            <VBox spacing="6.0">
               <children>
                  <Label styleClass="h3" text="Box ID" />
                  <TextField fx:id="txtFldBoxId" promptText="e.g. BOX-042" styleClass="container" />
               </children>
            </VBox>
            <HBox alignment="CENTER" spacing="9.0">
               <children>
                  <VBox>
                     <children>
            
                        <Label alignment="CENTER" minWidth="-Infinity" prefWidth="60.0" text="Rotation" />
                        <TextField fx:id="txtFldGlobalRotation" disable="true" editable="false" minWidth="-Infinity" prefWidth="60.0" styleClass="container">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets></TextField>
                     </children>
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </VBox>
                  <VBox layoutX="10.0" layoutY="10.0">
                     <children>
                        <Label alignment="CENTER" minWidth="-Infinity" prefWidth="60.0" text="Hue" />
                        <TextField fx:id="txtFldGlobalHue" disable="true" editable="false" minWidth="-Infinity" prefWidth="60.0" styleClass="container">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                        </TextField>
                     </children>
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </VBox>
                  <VBox layoutX="79.0" layoutY="10.0">
                     <children>
                        <Label alignment="CENTER" minWidth="-Infinity" prefWidth="60.0" text="Brightness" />
                        <TextField fx:id="txtFldGlobalBrightness" disable="true" editable="false" minWidth="-Infinity" prefWidth="60.0" styleClass="container">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                        </TextField>
                     </children>
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </VBox>
                  <VBox layoutX="79.0" layoutY="10.0">
                     <children>
                        <Label alignment="CENTER" minWidth="-Infinity" prefWidth="60.0" text="Contrast" />
                        <TextField fx:id="txtFldGlobalContrast" disable="true" editable="false" minWidth="-Infinity" prefWidth="60.0" styleClass="container">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                        </TextField>
                     </children>
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </VBox>
                  <VBox layoutX="79.0" layoutY="10.0">
                     <children>
                        <Label alignment="CENTER" minWidth="-Infinity" prefWidth="60.0" text="Saturation" />
                        <TextField fx:id="txtFldGlobalSaturation" disable="true" editable="false" minWidth="-Infinity" prefWidth="60.0" styleClass="container">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                        </TextField>
                     </children>
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </VBox>
               </children>
            </HBox>

            <Button mnemonicParsing="false" onAction="#onStartSession" prefHeight="33.0" styleClass="primary-btn" text="Start Session" />
            <Separator />
         </children>
      </VBox>
   </StackPane>
</StackPane>
