<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import org.controlsfx.control.*?>

<HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="780.0" prefWidth="780.0" styleClass="dark" stylesheets="@../css/mainStyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ScanHub.GUI.controllers.ProfileFormController">
    <children>
        <VBox prefHeight="750.0" prefWidth="750.0" styleClass="background" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" prefHeight="56" spacing="12.0" styleClass="primary-navigation-bg" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets left="20.0" right="20.0" />
                </padding>
                <Rectangle arcHeight="4" arcWidth="4" height="24.0" width="24.0" />
                <Label fx:id="formTitle" styleClass="h3" text="Create Profile" textFill="WHITE" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="profileIdLabel" text="" />
                <VBox.margin>
                    <Insets />
                </VBox.margin>
            </HBox>
            <HBox VBox.vgrow="ALWAYS">
                <children>
                    <VBox HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets bottom="6.0" left="12.0" right="6.0" top="12.0" />
                        </padding>
                        <VBox spacing="0">
                            <padding>
                                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                            </padding>
                            <Label styleClass="bold-lbl" text="Profile name" />
                            <Region prefHeight="6" />
                            <TextField fx:id="profileNameField" prefHeight="30" prefWidth="422.0" promptText="e.g. Maersk Oil" styleClass="container" />
                            <Region prefHeight="18" />
                            <Label layoutX="36.0" layoutY="36.0" styleClass="bold-lbl" text="Client" />
                            <SearchableComboBox fx:id="searchableComboBoxClient" prefHeight="30.0" prefWidth="422.0" />
                            <Region layoutX="36.0" layoutY="88.0" prefHeight="18" />
                            <Label styleClass="bold-lbl" text="Split Behavior" />
                            <Region prefHeight="4" />
                            <Label prefWidth="320.0" styleClass="lbl" text="Defines how documents are split during a scanning session." wrapText="true" />
                            <Region prefHeight="8" />
                            <VBox fx:id="vboxSplitBehavior" spacing="8">
                                <padding>
                                    <Insets bottom="14" left="14" right="14" top="14" />
                                </padding>
                                <HBox alignment="TOP_LEFT" spacing="10">
                                    <RadioButton fx:id="radioBARCODE">
                                        <toggleGroup>
                                            <ToggleGroup fx:id="toggleGroupSplitBehavior" />
                                        </toggleGroup>
                                    </RadioButton>
                                    <VBox spacing="2">
                                        <Label styleClass="lbl" text="Barcode" />
                                        <Label prefWidth="360" styleClass="lbl" text="A new document starts automatically when a barcode page is detected." wrapText="true" />
                                    </VBox>
                                </HBox>
                                <Separator />
                                <HBox alignment="TOP_LEFT" spacing="10">
                                    <RadioButton fx:id="radioNONE" toggleGroup="$toggleGroupSplitBehavior" />
                                    <VBox spacing="2">
                                        <Label styleClass="lbl" text="None" />
                                        <Label prefWidth="360" styleClass="lbl" text="No splitting. All scanned files are kept in one document." wrapText="true" />
                                    </VBox>
                                </HBox>
                                <styleClass>
                                    <String fx:value="card" />
                                    <String fx:value="second-card-bg" />
                                </styleClass>
                            </VBox>
                            <Region layoutX="35.0" layoutY="123.0" prefHeight="4" />
                            <styleClass>
                                <String fx:value="card" />
                                <String fx:value="card-bg" />
                            </styleClass>
                        </VBox>
                    </VBox>
                    <VBox layoutX="10.0" layoutY="10.0">
                        <padding>
                            <Insets bottom="6.0" left="6.0" right="12.0" top="12.0" />
                        </padding>
                        <children>
                            <VBox spacing="0">
                                <padding>
                                    <Insets bottom="24" left="24" right="24" top="24" />
                                </padding>
                                <children>
                                    <Label layoutX="35.0" layoutY="108.0" styleClass="bold-lbl" text="Profile Status" />
                                    <Region layoutX="35.0" layoutY="123.0" prefHeight="4" />
                                    <Label layoutX="35.0" layoutY="127.0" styleClass="lbl" text="Defines the state the profile is currently in." />
                                    <Region layoutX="35.0" layoutY="141.0" prefHeight="8" />
                                    <VBox fx:id="vboxStatus" layoutX="35.0" layoutY="149.0" spacing="8">
                                        <padding>
                                            <Insets bottom="14" left="14" right="14" top="14" />
                                        </padding>
                                        <children>
                                            <HBox alignment="TOP_LEFT" spacing="10">
                                                <children>
                                                    <RadioButton fx:id="radioACTIVE">
                                                        <toggleGroup>
                                                            <ToggleGroup fx:id="toggleGroupProfileStatus" />
                                                        </toggleGroup>
                                                    </RadioButton>
                                                    <VBox spacing="2">
                                                        <children>
                                                            <Label styleClass="lbl" text="Active" />
                                                            <Label prefWidth="360" styleClass="lbl" text="The profile is available for use and can be assigned to any user." wrapText="true" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </HBox>
                                            <Separator />
                                            <HBox alignment="TOP_LEFT" spacing="10">
                                                <children>
                                                    <RadioButton fx:id="radioINACTIVE" toggleGroup="$toggleGroupProfileStatus" />
                                                    <VBox spacing="2">
                                                        <children>
                                                            <Label styleClass="lbl" text="Inactive" />
                                                            <Label prefWidth="360" styleClass="lbl" text="The profile is unable to be utilized for scanning and cannot be assigned" wrapText="true" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </HBox>
                                        </children>
                                        <styleClass>
                                            <String fx:value="card" />
                                            <String fx:value="second-card-bg" />
                                        </styleClass>
                                    </VBox>
                                    <Region layoutX="35.0" layoutY="324.0" prefHeight="18" />
                                    <Label styleClass="bold-lbl" text="Export name preview" />
                                    <Region prefHeight="6" />
                                    <HBox alignment="CENTER_LEFT">
                                        <padding>
                                            <Insets bottom="8" left="12" right="12" top="8" />
                                        </padding>
                                        <children>
                                            <Label fx:id="exportPreviewLabel" text="ProfileName_24" />
                                        </children>
                                        <styleClass>
                                            <String fx:value="container" />
                                            <String fx:value="second-card-bg" />
                                        </styleClass>
                                    </HBox>
                                    <Label styleClass="helper-text" text="Format: {profileName}_{boxId}" />
                                    <Region prefHeight="18" />

                                    <!-- ── Image Adjustments ── -->
                                    <Label styleClass="bold-lbl" text="Image Adjustments" />
                                    <Region prefHeight="4" />
                                    <Label prefWidth="360" styleClass="lbl" text="Applied automatically to each scanned file on ingest." wrapText="true" />
                                    <Region prefHeight="8" />
                                    <VBox spacing="12">
                                        <padding>
                                            <Insets bottom="14" left="14" right="14" top="14" />
                                        </padding>
                                        <VBox spacing="4">
                                            <HBox alignment="CENTER_LEFT" spacing="8">
                                                <Label styleClass="lbl" text="Brightness" HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblBrightnessValue" styleClass="lbl" text="0" minWidth="30" />
                                            </HBox>
                                            <Slider fx:id="sliderBrightness" min="-100" max="100" value="0"
                                                    blockIncrement="1" showTickLabels="false" prefHeight="30" />
                                        </VBox>
                                        <Separator />
                                        <VBox spacing="4">
                                            <HBox alignment="CENTER_LEFT" spacing="8">
                                                <Label styleClass="lbl" text="Contrast" HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblContrastValue" styleClass="lbl" text="0" minWidth="30" />
                                            </HBox>
                                            <Slider fx:id="sliderContrast" min="-100" max="100" value="0"
                                                    blockIncrement="1" showTickLabels="false" prefHeight="30" />
                                        </VBox>
                                        <styleClass>
                                            <String fx:value="card" />
                                            <String fx:value="second-card-bg" />
                                        </styleClass>
                                    </VBox>

                                </children>
                                <styleClass>
                                    <String fx:value="card" />
                                    <String fx:value="card-bg" />
                                </styleClass>
                            </VBox>
                        </children>
                    </VBox>
                </children>
            </HBox>
            <HBox prefHeight="100.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                <children>
                    <VBox HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="6.0" />
                        </padding>
                        <children>
                            <VBox spacing="0">
                                <padding>
                                    <Insets bottom="24" left="24" right="24" top="24" />
                                </padding>
                                <children>
                                    <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="30.0">
                                        <children>
                                            <Label styleClass="bold-lbl" text="Assign profile to users" />
                                            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                                            <TextField maxWidth="-Infinity" minWidth="-Infinity" prefHeight="30.0" prefWidth="180.0" promptText="Filter users" styleClass="container" />
                                        </children>
                                    </HBox>
                                    <Region maxHeight="-Infinity" minHeight="-Infinity" prefHeight="18.0" />
                                    <ScrollPane fitToWidth="true" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="150.0" prefWidth="200.0" styleClass="card">
                                        <content>
                                            <VBox fx:id="vboxUsers" prefHeight="50.0" prefWidth="100.0" />
                                        </content>
                                    </ScrollPane>
                                    <Region layoutX="35.0" layoutY="123.0" prefHeight="4" />
                                </children>
                                <styleClass>
                                    <String fx:value="card" />
                                    <String fx:value="card-bg" />
                                </styleClass>
                            </VBox>
                        </children>
                    </VBox>
                </children>
            </HBox>
            <HBox alignment="CENTER_RIGHT" prefHeight="56.0" spacing="8" VBox.vgrow="NEVER">
                <padding>
                    <Insets bottom="0" left="24" right="24" top="0" />
                </padding>
                <Button onAction="#onClickCancel" prefHeight="30" styleClass="tertiary-btn" text="Cancel" />
                <Button fx:id="saveButton" defaultButton="true" onAction="#onClickSave" prefHeight="33" styleClass="primary-btn" text="Create Profile" />
            </HBox>
        </VBox>
    </children>
</HBox>