<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ScanHub.GUI.controllers.ProfileFormController"
      prefWidth="520"
      style="-fx-background-color: #F5F5F5;">
    <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>
    <HBox prefHeight="56" alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #2D3D4F;">
        <padding><Insets top="0" right="20" bottom="0" left="20"/></padding>
        <Rectangle width="8" height="28" arcWidth="4" arcHeight="4"
                   style="-fx-fill: #24C79F;"/>
        <Label fx:id="formTitle" text="Create profile"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="profileIdLabel" text=""
               style="-fx-font-size: 11px; -fx-text-fill: #9DB4C4;"/>
    </HBox>
    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: #F5F5F5;">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 10;
                     -fx-border-color: #E2E4E8; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
            <Label text="Profile name"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;"/>
            <Region prefHeight="6"/>
            <TextField fx:id="profileNameField" promptText="e.g. Maersk Oil" prefHeight="30"
                       style="-fx-font-size: 12px; -fx-background-color: white;
                              -fx-border-color: #E2E4E8; -fx-border-radius: 6;
                              -fx-background-radius: 6; -fx-border-width: 1;
                              -fx-text-fill: #2D3D4F; -fx-prompt-text-fill: #BFBFBF;"/>
            <Label fx:id="nameError" text="Profile name is required."
                   visible="false" managed="false"
                   style="-fx-font-size: 10px; -fx-text-fill: #FF3D32;"/>
            <Region prefHeight="18"/>
            <Label text="Split behaviour"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;"/>
            <Region prefHeight="4"/>
            <Label text="Defines how documents are split during a scanning session."
                   style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
            <Region prefHeight="8"/>
            <VBox spacing="8"
                  style="-fx-background-color: #F9F9F9; -fx-background-radius: 6;
                         -fx-border-color: #E2E4E8; -fx-border-radius: 6; -fx-border-width: 1;">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <HBox spacing="10" alignment="TOP_LEFT">
                    <RadioButton fx:id="radioBARCODE" selected="true"
                                 style="-fx-font-size: 12px; -fx-text-fill: #2D3D4F;"/>
                    <VBox spacing="2">
                        <Label text="Barcode"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;"/>
                        <Label text="A new document starts automatically when a barcode page is detected."
                               wrapText="true" prefWidth="360"
                               style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                    </VBox>
                </HBox>
                <Separator/>
                <HBox spacing="10" alignment="TOP_LEFT">
                    <RadioButton fx:id="radioMANUAL"
                                 style="-fx-font-size: 12px; -fx-text-fill: #2D3D4F;"/>
                    <VBox spacing="2">
                        <Label text="Manual"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;"/>
                        <Label text="The user decides manually when to start a new document."
                               wrapText="true" prefWidth="360"
                               style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                    </VBox>
                </HBox>
                <Separator/>
                <HBox spacing="10" alignment="TOP_LEFT">
                    <RadioButton fx:id="radioNONE"
                                 style="-fx-font-size: 12px; -fx-text-fill: #2D3D4F;"/>
                    <VBox spacing="2">
                        <Label text="None"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;"/>
                        <Label text="No splitting. All scanned files are kept in one document."
                               wrapText="true" prefWidth="360"
                               style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                    </VBox>
                </HBox>
            </VBox>
            <Region prefHeight="18"/>
            <Label text="Export name preview"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;"/>
            <Region prefHeight="6"/>
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: #F9F9F9; -fx-background-radius: 6;
                         -fx-border-color: #E2E4E8; -fx-border-radius: 6; -fx-border-width: 1;">
                <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
                <Label fx:id="exportPreviewLabel" text="ProfileName_BOX-042.tiff"
                       style="-fx-font-size: 12px; -fx-font-family: monospace; -fx-text-fill: #2D3D4F;"/>
            </HBox>
            <Label text="Format: {profileName}_{boxLabel}.tiff"
                   style="-fx-font-size: 10px; -fx-text-fill: #BFBFBF;"/>

            <Region prefHeight="18"/>
            <Label text="Assign users"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;"/>
            <Region prefHeight="4"/>
            <Label text="Select which users can access this profile."
                   style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
            <Region prefHeight="8"/>
            <VBox fx:id="userCheckboxList" spacing="6"
                  style="-fx-background-color: #F9F9F9; -fx-background-radius: 6;
                         -fx-border-color: #E2E4E8; -fx-border-radius: 6; -fx-border-width: 1;">
                <padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
                <Label text="Loading users..."
                       style="-fx-font-size: 11px; -fx-text-fill: #BFBFBF;"/>
            </VBox>
            <Region prefHeight="6"/>
            <Label fx:id="usersError" text="Assign at least one user."
                   visible="false" managed="false"
                   style="-fx-font-size: 10px; -fx-text-fill: #FF3D32;"/>
        </VBox>
    </VBox>
    <HBox prefHeight="56" alignment="CENTER_RIGHT" spacing="8"
          style="-fx-background-color: #F5F5F5;
                 -fx-border-color: #E2E4E8; -fx-border-width: 1 0 0 0;">
        <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>
        <Button text="Cancel" prefHeight="30" onAction="#handleCancel"
                style="-fx-font-size: 12px; -fx-background-color: white;
                       -fx-border-color: #E2E4E8; -fx-border-radius: 6;
                       -fx-background-radius: 6; -fx-border-width: 1;
                       -fx-text-fill: #2D3D4F; -fx-cursor: hand; -fx-padding: 0 16 0 16;"/>
        <Button fx:id="saveButton" text="Create profile" prefHeight="33"
                onAction="#handleSave" defaultButton="true"
                style="-fx-font-size: 12px; -fx-font-weight: bold;
                       -fx-background-color: #2D3D4F; -fx-background-radius: 6;
                       -fx-text-fill: white; -fx-border-width: 0;
                       -fx-cursor: hand; -fx-padding: 0 20 0 20;"/>
    </HBox>
</VBox>
