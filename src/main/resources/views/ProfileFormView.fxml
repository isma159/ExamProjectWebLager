<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.*?>

<HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1200.0" stylesheets="@../css/mainStyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ScanHub.GUI.controllers.ProfileFormController">
    <children>
        <VBox prefHeight="750.0" prefWidth="750.0" styleClass="background" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="60.0" spacing="12.0" styleClass="primary-navigation-bg" VBox.vgrow="NEVER">
                <padding>
                    <Insets left="20.0" right="20.0" />
                </padding>
            <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/Green/WeblagerGreenIcon.png" />
               </image>
            </ImageView>
                <Label fx:id="formTitle" styleClass="h3" text="Create Profile" textFill="WHITE" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="profileIdLabel" text="" />
                <VBox.margin>
                    <Insets />
                </VBox.margin>
            </HBox>
            <HBox spacing="12.0" VBox.vgrow="ALWAYS">
                <children>
                     <VBox spacing="0">
                         <padding>
                             <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                         </padding>
                         <Label styleClass="bold-lbl" text="Profile name" />
                         <Region prefHeight="6" />
                         <TextField fx:id="profileNameField" prefHeight="30" prefWidth="422.0" promptText="e.g. Maersk Oil" styleClass="container" />
                         <Region prefHeight="15.0" />
                         <Label layoutX="36.0" layoutY="36.0" styleClass="bold-lbl" text="Client" />
                  <Region layoutX="36.0" layoutY="51.0" prefHeight="6" />
                         <SearchableComboBox fx:id="searchableComboBoxClient" prefHeight="30.0" prefWidth="422.0" />
                           <Region prefHeight="15.0" />
                  <Label styleClass="bold-lbl" text="Export name preview" />
                  <Region prefHeight="6" />
                  <HBox alignment="CENTER_LEFT">
                     <padding>
                        <Insets bottom="8" left="12" right="12" top="8" />
                     </padding>
                     <styleClass>
                        <String fx:value="container" />
                        <String fx:value="second-card-bg" />
                     </styleClass>
                     <children>
                        <Label fx:id="exportPreviewLabel" text="ClientName_ProfileName_24" />
                     </children>
                  </HBox>
                  <Label styleClass="helper-text" text="Format: {clientName}_{profileName}_{boxId}" />
                  <Region prefHeight="15.0" />
                  <Label styleClass="bold-lbl" text="Profile Status" />
                  <Region prefHeight="4" />
                  <Label styleClass="lbl" text="Defines the state the profile is currently in." />
                  <Region prefHeight="8" />
                  <VBox fx:id="vboxStatus" spacing="8">
                     <padding>
                        <Insets bottom="14" left="14" right="14" top="14" />
                     </padding>
                     <children>
                        <HBox alignment="TOP_LEFT" spacing="10">
                           <children>
                              <RadioButton fx:id="radioACTIVE">
                                 <toggleGroup>
                                    <ToggleGroup fx:id="toggleGroupProfileStatus" />
                                 </toggleGroup>
                              </RadioButton>
                              <VBox spacing="2">
                                 <children>
                                    <Label styleClass="lbl" text="Active" />
                                    <Label prefWidth="360" styleClass="lbl" text="The profile is available for use and can be assigned to any user." wrapText="true" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <Separator />
                        <HBox alignment="TOP_LEFT" spacing="10">
                           <children>
                              <RadioButton fx:id="radioINACTIVE" toggleGroup="$toggleGroupProfileStatus" />
                              <VBox spacing="2">
                                 <children>
                                    <Label styleClass="lbl" text="Inactive" />
                                    <Label prefWidth="360" styleClass="lbl" text="The profile is unable to be utilized for scanning and cannot be assigned" wrapText="true" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                     <styleClass>
                        <String fx:value="card" />
                        <String fx:value="second-card-bg" />
                     </styleClass>
                  </VBox>
                         <styleClass>
                             <String fx:value="card" />
                             <String fx:value="card-bg" />
                         </styleClass>
                     </VBox>
               <VBox spacing="12.0">
                  <styleClass>
                     <String fx:value="card" />
                     <String fx:value="card-bg" />
                  </styleClass>
                  <children>

                              <!-- ── Image Adjustments ── -->
                              <Label styleClass="bold-lbl" text="Image Adjustments" />
                     <HBox layoutX="12.0" layoutY="12.0" prefHeight="248.0" prefWidth="600.0" spacing="12.0">
                        <children>
                                    <VBox spacing="12.0">
                              <VBox spacing="4">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="15.0" spacing="8">
                                       <children>
                                          <Label maxWidth="-Infinity" minWidth="-Infinity" prefWidth="120.0" styleClass="lbl" text="Hue" HBox.hgrow="ALWAYS" />
                                          <Region prefHeight="15.0" prefWidth="60.0" HBox.hgrow="ALWAYS" />
                                          <Spinner fx:id="spnHue" editable="true" maxWidth="-Infinity" minWidth="-Infinity" prefHeight="30.0" prefWidth="60.0" styleClass="arrowless-spinner" />
                                       </children>
                                    </HBox>
                                    <Slider fx:id="sliderHue" blockIncrement="1" max="100" min="-100" minorTickCount="1" prefHeight="30" showTickLabels="false" snapToTicks="true" value="0" />
                                 </children>
                              </VBox>
                              <Separator />
                                        <VBox spacing="4">
                                 <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="15.0" spacing="8">
                                    <children>
                                       <Label maxWidth="-Infinity" minWidth="-Infinity" prefWidth="120.0" styleClass="lbl" text="Brightness" HBox.hgrow="ALWAYS" />
                                       <Region prefHeight="15.0" prefWidth="60.0" HBox.hgrow="ALWAYS" />
                                       <Spinner fx:id="spnBrightness" editable="true" maxWidth="-Infinity" minWidth="-Infinity" prefHeight="30.0" prefWidth="60.0" styleClass="arrowless-spinner" />
                                    </children>
                                 </HBox>
                                            <Slider fx:id="sliderBrightness" blockIncrement="1" max="100" min="-100" minorTickCount="1" prefHeight="30" showTickLabels="false" snapToTicks="true" value="0" />
                                        </VBox>
                                        <Separator />
                              <VBox spacing="4">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="15.0" spacing="8">
                                       <children>
                                          <Label maxWidth="-Infinity" minWidth="-Infinity" prefWidth="120.0" styleClass="lbl" text="Global Rotation" HBox.hgrow="ALWAYS" />
                                          <Region prefHeight="15.0" prefWidth="60.0" HBox.hgrow="ALWAYS" />
                                          <Spinner fx:id="spnRotation" editable="true" maxWidth="-Infinity" minWidth="-Infinity" prefHeight="30.0" prefWidth="60.0" styleClass="arrowless-spinner" />
                                       </children>
                                    </HBox>
                                    <Slider fx:id="sliderRotation" blockIncrement="5.0" majorTickUnit="90.0" max="270.0" min="-270.0" minorTickCount="5" prefHeight="30" showTickLabels="true" showTickMarks="true" snapToTicks="true" value="0" />
                                 </children>
                              </VBox>
                                    </VBox>
                           <VBox spacing="12.0">
                              <children>
                                           <VBox spacing="4">
                                    <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="15.0" spacing="8">
                                       <children>
                                          <Label maxWidth="-Infinity" minWidth="-Infinity" prefWidth="120.0" styleClass="lbl" text="Contrast" HBox.hgrow="ALWAYS" />
                                          <Region prefHeight="15.0" prefWidth="60.0" HBox.hgrow="ALWAYS" />
                                          <Spinner fx:id="spnContrast" editable="true" maxWidth="-Infinity" minWidth="-Infinity" prefHeight="30.0" prefWidth="60.0" styleClass="arrowless-spinner" />
                                       </children>
                                    </HBox>
                                               <Slider fx:id="sliderContrast" blockIncrement="1" max="100" min="-100" minorTickCount="1" prefHeight="30" showTickLabels="false" snapToTicks="true" value="0" />
                                           </VBox>
                                 <Separator />
                                 <VBox spacing="4">
                                    <children>
                                       <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="15.0" spacing="8">
                                          <children>
                                             <Label maxWidth="-Infinity" minWidth="-Infinity" prefWidth="120.0" styleClass="lbl" text="Saturation" HBox.hgrow="ALWAYS" />
                                             <Region prefHeight="15.0" prefWidth="60.0" HBox.hgrow="ALWAYS" />
                                             <Spinner fx:id="spnSaturation" editable="true" maxWidth="-Infinity" minWidth="-Infinity" prefHeight="30.0" prefWidth="60.0" styleClass="arrowless-spinner" />
                                          </children>
                                       </HBox>
                                       <Slider fx:id="sliderSaturation" blockIncrement="1" max="100" min="-100" minorTickCount="1" prefHeight="30" showTickLabels="false" snapToTicks="true" value="0" />
                                    </children>
                                 </VBox>
                                 <Separator />
                              </children>
                           </VBox>
                        </children>
                        <styleClass>
                           <String fx:value="card" />
                           <String fx:value="second-card-bg" />
                        </styleClass>
                        <padding>
                           <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                        </padding>
                     </HBox>
                     <HBox prefHeight="245.0">
                        <children>
                           <VBox alignment="CENTER" prefHeight="226.0" prefWidth="270.0">
                              <styleClass>
                                 <String fx:value="card" />
                                 <String fx:value="second-card-bg" />
                              </styleClass>
                              <children>
                                 <ImageView fx:id="imgPreview" fitHeight="200.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" VBox.vgrow="ALWAYS">
                                          <image>
                                       <Image url="@../images/placeholders/placeholder-image.png" />
                                    </image>
                                 </ImageView>
                              </children>
                           </VBox>
                           <Region prefHeight="200.0" prefWidth="60.0" />
                           <VBox alignment="CENTER" prefHeight="200.0" prefWidth="270.0">
                              <styleClass>
                                 <String fx:value="card" />
                                 <String fx:value="second-card-bg" />
                              </styleClass>
                              <children>
                                 <ImageView fitHeight="200.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" VBox.vgrow="ALWAYS">
                                    <image>
                                       <Image url="@../images/placeholders/placeholder-image.png" />
                                    </image>
                                 </ImageView>
                              </children>
                           </VBox>
                        </children>
                     </HBox>
                  </children>
                  <padding>
                     <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                  </padding>
               </VBox>
                </children>
            <VBox.margin>
               <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
            </VBox.margin>
            </HBox>
            <HBox alignment="CENTER_RIGHT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="45.0" spacing="8" VBox.vgrow="NEVER">
                <padding>
                    <Insets left="12.0" right="12.0" />
                </padding>
                <Button onAction="#onClickCancel" prefHeight="30" styleClass="tertiary-btn" text="Cancel" />
                <Button fx:id="saveButton" defaultButton="true" onAction="#onClickSave" prefHeight="33" styleClass="primary-btn" text="Create Profile" />
            </HBox>
        </VBox>
    </children>
</HBox>
