<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox prefHeight="750.0" prefWidth="750.0" stylesheets="@../css/mainStyle.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ScanHub.GUI.controllers.ProfileFormController">
    <padding><Insets bottom="0" left="0" right="0" top="0" /></padding>
    <HBox alignment="CENTER_LEFT" prefHeight="56" spacing="12" style="-fx-background-color: #2D3D4F;">
        <padding><Insets bottom="0" left="20" right="20" top="0" /></padding>
        <Rectangle arcHeight="4" arcWidth="4" height="28" style="-fx-fill: #24C79F;" width="8" />
        <Label fx:id="formTitle" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" text="Create profile" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="profileIdLabel" style="-fx-font-size: 11px; -fx-text-fill: #9DB4C4;" text="" />
    </HBox>
   <HBox VBox.vgrow="ALWAYS">
      <children>
          <VBox style="-fx-background-color: #F5F5F5;" HBox.hgrow="ALWAYS">
              <padding>
               <Insets bottom="6.0" left="12.0" right="6.0" top="12.0" />
            </padding>
              <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 10;                      -fx-border-color: #E2E4E8; -fx-border-radius: 10; -fx-border-width: 1;">
                  <padding>
                  <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
               </padding>
                  <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="Profile name" />
                  <Region prefHeight="6" />
                  <TextField fx:id="profileNameField" prefHeight="30" prefWidth="422.0" promptText="e.g. Maersk Oil" styleClass="container" />
                  <Region prefHeight="18" />
                  <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="Split Behavior" />
                  <Region prefHeight="4" />
                  <Label style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="Defines how documents are split during a scanning session." />
                  <Region prefHeight="8" />
                  <VBox fx:id="vboxSplitBehavior" spacing="8" styleClass="container">
                      <padding>
                     <Insets bottom="14" left="14" right="14" top="14" />
                  </padding>
                      <HBox alignment="TOP_LEFT" spacing="10">
                          <RadioButton fx:id="radioBARCODE" style="-fx-font-size: 12px; -fx-text-fill: #2D3D4F;">
                        <toggleGroup>
                           <ToggleGroup fx:id="toggleGroupSplitBehavior" />
                        </toggleGroup>
                     </RadioButton>
                          <VBox spacing="2">
                              <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="Barcode" />
                              <Label prefWidth="360" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="A new document starts automatically when a barcode page is detected." wrapText="true" />
                          </VBox>
                      </HBox>
                      <Separator />
                      <HBox alignment="TOP_LEFT" spacing="10">
                          <RadioButton fx:id="radioMANUAL" style="-fx-font-size: 12px; -fx-text-fill: #2D3D4F;" toggleGroup="$toggleGroupSplitBehavior" />
                          <VBox spacing="2">
                              <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="Manual" />
                              <Label prefWidth="360" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="The user decides manually when to start a new document." wrapText="true" />
                          </VBox>
                      </HBox>
                      <Separator />
                      <HBox alignment="TOP_LEFT" spacing="10">
                          <RadioButton fx:id="radioNONE" style="-fx-font-size: 12px; -fx-text-fill: #2D3D4F;" toggleGroup="$toggleGroupSplitBehavior" />
                          <VBox spacing="2">
                              <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="None" />
                              <Label prefWidth="360" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="No splitting. All scanned files are kept in one document." wrapText="true" />
                          </VBox>
                      </HBox>
                  </VBox>
               <Region layoutX="35.0" layoutY="123.0" prefHeight="4" />
              </VBox>
          </VBox>
         <VBox layoutX="10.0" layoutY="10.0" style="-fx-background-color: #F5F5F5;">
            <padding>
               <Insets bottom="6.0" left="6.0" right="12.0" top="12.0" />
            </padding>
            <children>
               <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 10;                      -fx-border-color: #E2E4E8; -fx-border-radius: 10; -fx-border-width: 1;">
                  <padding>
                     <Insets bottom="24" left="24" right="24" top="24" />
                  </padding>
                  <children>
                     <Label layoutX="35.0" layoutY="108.0" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="Profile Status" />
                     <Region layoutX="35.0" layoutY="123.0" prefHeight="4" />
                     <Label layoutX="35.0" layoutY="127.0" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="Defines the state the profile is currently in." />
                     <Region layoutX="35.0" layoutY="141.0" prefHeight="8" />
                     <VBox fx:id="vboxStatus1" layoutX="35.0" layoutY="149.0" spacing="8" styleClass="container">
                        <padding>
                           <Insets bottom="14" left="14" right="14" top="14" />
                        </padding>
                        <children>
                           <HBox alignment="TOP_LEFT" spacing="10">
                              <children>
                                 <RadioButton fx:id="radioACTIVE" style="-fx-font-size: 12px; -fx-text-fill: #2D3D4F;">
                                    <toggleGroup>
                                       <ToggleGroup fx:id="toggleGroupProfileStatus1" />
                                    </toggleGroup>
                                 </RadioButton>
                                 <VBox spacing="2">
                                    <children>
                                       <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="Active" />
                                       <Label prefWidth="360" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="The profile is available for use and can be assigned to any user." wrapText="true" />
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>
                           <Separator />
                           <HBox alignment="TOP_LEFT" spacing="10">
                              <children>
                                 <RadioButton fx:id="radioINACTIVE" style="-fx-font-size: 12px; -fx-text-fill: #2D3D4F;" toggleGroup="$toggleGroupProfileStatus1" />
                                 <VBox spacing="2">
                                    <children>
                                       <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="Inactive" />
                                       <Label prefWidth="360" style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="The profile is unable to be utilized for scanning and cannot be assigned" wrapText="true" />
                                    </children>
                                 </VBox>
                              </children>
                           </HBox>
                        </children>
                     </VBox>
                     <Region layoutX="35.0" layoutY="324.0" prefHeight="18" />
                     <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="Export name preview" />
                     <Region prefHeight="6" />
                     <HBox alignment="CENTER_LEFT" styleClass="container">
                        <padding>
                           <Insets bottom="8" left="12" right="12" top="8" />
                        </padding>
                        <children>
                           <Label fx:id="exportPreviewLabel" style="-fx-font-size: 12px; -fx-font-family: monospace; -fx-text-fill: #2D3D4F;" text="ProfileName_24" />
                        </children>
                     </HBox>
                     <Label style="-fx-font-size: 10px; -fx-text-fill: #BFBFBF;" text="Format: {profileName}_{boxId}" />
                     <Region prefHeight="45.0" />
                  </children>
               </VBox>
            </children>
         </VBox>
      </children>
   </HBox>
   <HBox prefHeight="100.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
      <children>
         <VBox style="-fx-background-color: #F5F5F5;" HBox.hgrow="ALWAYS">
            <padding>
               <Insets bottom="12.0" left="12.0" right="12.0" top="6.0" />
            </padding>
            <children>
               <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 10;                      -fx-border-color: #E2E4E8; -fx-border-radius: 10; -fx-border-width: 1;">
                  <padding>
                     <Insets bottom="24" left="24" right="24" top="24" />
                  </padding>
                  <children>
                     <HBox alignment="CENTER_LEFT" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="30.0">
                        <children>
                           <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2D3D4F;" text="Assign profile to users" />
                           <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                           <TextField maxWidth="-Infinity" minWidth="-Infinity" prefHeight="30.0" prefWidth="180.0" promptText="Filter users" styleClass="container" />
                        </children>
                     </HBox>
                     <Region maxHeight="-Infinity" minHeight="-Infinity" prefHeight="18.0" />
                     <ScrollPane fitToWidth="true" maxHeight="-Infinity" minHeight="-Infinity" prefHeight="150.0" prefWidth="200.0" styleClass="card">
                        <content>
                           <VBox prefHeight="50.0" prefWidth="100.0" />
                        </content>
                     </ScrollPane>
                     <Region layoutX="35.0" layoutY="123.0" prefHeight="4" />
                  </children>
               </VBox>
            </children>
         </VBox>
      </children>
   </HBox>
    <HBox alignment="CENTER_RIGHT" prefHeight="56" spacing="8" style="-fx-background-color: #F5F5F5;                  -fx-border-color: #E2E4E8; -fx-border-width: 1 0 0 0;">
        <padding><Insets bottom="0" left="24" right="24" top="0" /></padding>
        <Button onAction="#onClickCancel" prefHeight="30" style="-fx-font-size: 12px; -fx-background-color: white;                        -fx-border-color: #E2E4E8; -fx-border-radius: 6;                        -fx-background-radius: 6; -fx-border-width: 1;                        -fx-text-fill: #2D3D4F; -fx-cursor: hand; -fx-padding: 0 16 0 16;" text="Cancel" />
        <Button fx:id="saveButton" defaultButton="true" onAction="#onClickSave" prefHeight="33" style="-fx-font-size: 12px; -fx-font-weight: bold;                        -fx-background-color: #2D3D4F; -fx-background-radius: 6;                        -fx-text-fill: white; -fx-border-width: 0;                        -fx-cursor: hand; -fx-padding: 0 20 0 20;" text="Create profile" />
    </HBox>
</VBox>
